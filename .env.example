# Copy this file to a local .env (do not commit the real one)
TRAINPULSE_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token
TRAINPULSE_MESSAGE_TYPE=post
# Silent local liveness check interval in minutes (HEARTBEAT is stored locally; no webhook push)
TRAINPULSE_HEARTBEAT_MINUTES=30
TRAINPULSE_DRY_RUN=false
# Comma-separated regex list
TRAINPULSE_REDACT=(?i)(token=)\\S+
# Optional paths
# TRAINPULSE_STORE_PATH=~/.local/state/trainpulse/runs.db
# TRAINPULSE_ERROR_LOG_PATH=~/.local/state/trainpulse/error.log
