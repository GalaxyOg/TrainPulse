# Copy this file to a local .env (do not commit the real one)
TRAIN_NOTIFY_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token
TRAIN_NOTIFY_MESSAGE_TYPE=post
TRAIN_NOTIFY_HEARTBEAT_MINUTES=30
TRAIN_NOTIFY_DRY_RUN=false
# Comma-separated regex list
TRAIN_NOTIFY_REDACT=(?i)(token=)\\S+
# Optional paths
# TRAIN_NOTIFY_STORE_PATH=~/.local/state/train-notify/runs.db
# TRAIN_NOTIFY_ERROR_LOG_PATH=~/.local/state/train-notify/error.log
